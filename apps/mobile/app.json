{
  "expo": {
    "name": "ValuCore Africa",
    "slug": "valucore-africa",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "valucore-africa",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0b6a38"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.valucoreafrica.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Capture property and inspection photos directly from ValuCore Africa.",
        "NSPhotoLibraryUsageDescription": "Select existing property and inspection photos from your library.",
        "NSPhotoLibraryAddUsageDescription": "Allow ValuCore Africa to attach selected photos to inspection records."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b6a38"
      },
      "package": "com.valucoreafrica.app"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-camera",
      "expo-document-picker",
      "expo-image-picker",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
