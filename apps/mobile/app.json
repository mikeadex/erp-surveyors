{
  "expo": {
    "name": "Valuation OS",
    "slug": "valuation-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "valuation-os",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.valuationos.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563eb"
      },
      "package": "com.valuationos.app"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-camera",
      "expo-image-picker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
